{
  "name": "aws-saa-study",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "pages:build": "next build && bunx next-on-pages",
    "start": "next start",
    "test": "echo \"No tests configured\"",
    "lint": "eslint",
    "deploy": "next build && bunx next-on-pages && bunx wrangler pages deploy --commit-dirty=true",
    "scrape:quiz": "bun run scripts/scrape-whizlabs-quiz.ts",
    "scrape:lab": "bun run scripts/scrape-course-lab.ts",
    "seed:labs": "bun run scripts/seed-labs.ts",
    "labs:compile": "bun run scripts/compile-labs-from-json.ts",
    "labs:sanitize": "bun run scripts/sanitize-labs-data.ts",
    "capture:questions": "bun run scripts/capture-question-screenshots.ts",
    "seed:screenshots": "bun run scripts/seed-screenshot-metadata.ts",
    "verify:aws-refs": "bun run scripts/verify-aws-references.ts",
    "changelog:draft": "bun run scripts/changelog-from-git.ts",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "next": "16.2.4",
    "postcss": "^8.5.13",
    "react": "19.3.0-canary-43bcbf80-20260603",
    "react-dom": "19.3.0-canary-43bcbf80-20260603"
  },
  "overrides": {
    "postcss": "^8.5.13"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260519.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10",
    "eslint-config-next": "16.2.4",
    "playwright": "^1.52.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^6",
    "wrangler": "^4.93.0"
  }
}
