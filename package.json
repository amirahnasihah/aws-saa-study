{
  "name": "aws-saa-study",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "bun run scripts/generate-ai-link-indexes.ts && next dev --turbopack",
    "dev:webpack": "next dev",
    "dev:clean": "rm -rf .next && next dev --turbopack",
    "build": "next build",
    "pages:build": "bun run scripts/generate-ai-link-indexes.ts && next build && bunx next-on-pages",
    "start": "next start",
    "test": "bun test",
    "lint": "eslint",
    "deploy": "bun run pages:build && bunx wrangler pages deploy --commit-dirty=true",
    "scrape:quiz": "bun run scripts/scrape-quiz.ts",
    "practice:discover": "bun run scripts/discover-practice-tests.ts",
    "practice:images": "bun run scripts/scrape-practice-images.ts",
    "practice:verify": "bun run scripts/verify-practice-images.ts",
    "scrape:lab": "bun run scripts/scrape-course-lab.ts",
    "scrape:lab:checklist": "bun run scripts/scrape-checklist-labs.ts",
    "scrape:lab:checklist:import": "bun run scripts/scrape-checklist-labs.ts -- --compile --cdp-endpoint chrome",
    "scrape:lab:images": "bun run scripts/scrape-course-lab.ts -- --batch --missing-images --cdp-endpoint chrome",
    "scrape:lab:guided-images": "bun run scripts/scrape-course-lab.ts -- --batch --under-scraped --guided-only --headless --compile",
    "scrape:videos": "bun run scripts/scrape-course-videos.ts",
    "course:archive": "bun run scripts/export-course-archive.ts",
    "seed:labs": "bun run scripts/seed-labs.ts",
    "labs:compile": "bun run scripts/compile-labs-from-json.ts && bun run scripts/generate-labs-topics.ts && bun run scripts/generate-labs-checklist.ts && bun run scripts/generate-labs-library-order.ts",
    "labs:library:order": "bun run scripts/generate-labs-library-order.ts",
    "labs:verify": "bun run scripts/verify-labs-offline.ts",
    "labs:loop": "bun run scripts/loop-library-pipeline.ts",
    "labs:topics": "bun run scripts/generate-labs-topics.ts",
    "labs:checklist": "bun run scripts/generate-labs-checklist.ts",
    "labs:library:discover": "bun run scripts/discover-library-labs.ts",
    "labs:library:audit": "bun run scripts/audit-library-labs.ts",
    "labs:library:scrape": "bun run scripts/scrape-library-labs.ts",
    "labs:sanitize": "bun run scripts/sanitize-labs-data.ts",
    "capture:questions": "bun run scripts/capture-question-screenshots.ts",
    "seed:screenshots": "bun run scripts/seed-screenshot-metadata.ts",
    "verify:aws-refs": "bun run scripts/verify-aws-references.ts",
    "changelog:draft": "bun run scripts/changelog-from-git.ts",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "rag:sync": "bun run scripts/sync-rag-index.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@xyflow/react": "^12.10.2",
    "mermaid": "^11.15.0",
    "motion": "^12.40.0",
    "next": "16.2.4",
    "postcss": "^8.5.13",
    "react": "19.3.0-canary-43bcbf80-20260603",
    "react-dom": "19.3.0-canary-43bcbf80-20260603",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "overrides": {
    "postcss": "^8.5.13"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260519.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10",
    "eslint-config-next": "16.2.4",
    "playwright": "^1.52.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^7",
    "wrangler": "^4.93.0"
  }
}
