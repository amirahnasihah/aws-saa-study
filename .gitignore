# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.playwright-mcp

# env files (can opt-in for committing if needed)
.env*
.dev.vars

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# cloudflare wrangler local state
.wrangler/

# ---------------------------------------------------------------------------
# scripts/ — generated outputs (regenerate from *.ts or labs/*.json)
# Commit: *.ts tooling, labs/*.json, labs/course-index.json, labs-schema.sql
# Ignore: *.sql seeds, auth state, debug HTML
# ---------------------------------------------------------------------------
scripts/*.sql
scripts/*-notes.json
scripts/debug-q*.html

# lab scrape (bun run labs:sanitize regenerates SQL from JSON)
scripts/labs/*.sql
scripts/labs/batch-seed.sql
scripts/labs/debug-*.html

# question capture (local URLs + auth state)
scripts/question-pages.local.json
scripts/.playwright-storage-state.json
scripts/aws-reference-report.json
public/questions/wz*/debug-*.html

# local mcp config
.mcp.json
.cursor/mcp.json

# impeccable runtime & live mode (commit skills/, PRODUCT.md, DESIGN.md)
.impeccable/hook.cache.json
.impeccable/live/server.json
.impeccable/live/sessions/
.impeccable/live/previews/
.impeccable/live/annotations/
.impeccable/live/cache/
.impeccable/live/manual-edit-*
.impeccable/live/pending-manual-edits.json
.impeccable/live/deferred-svelte-component-accepts.json
.impeccable/critique/
.impeccable-live/
.impeccable-live.json
node_modules/.impeccable-live/
src/lib/impeccable/ImpeccableLiveRoot.svelte
src/lib/impeccable/__runtime.js
